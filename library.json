{
  "name": "lib-soogh",
  "version": "0.10.1+260419",
  "description": "Object-oriented GUI framework wrapping LVGL v9 and LovyanGFX for ESP32 embedded displays. Provides a screen stack, event routing, and hardware abstraction for M5Stack Core, M5Stack Core2, WT32-SC01 and Waveshare LCD4 devices.",
  "keywords": ["lvgl", "lovyangfx", "gui", "esp32", "m5stack", "display", "embedded"],
  "repository": {
    "type": "git",
    "url": "https://github.com/knifter/lib-soogh"
  },
  "authors": {
    "name": "Tijs van Roon",
    "email": "knifter@gmail.com",
    "url": "https://github.com/knifter",
    "maintainer": true
  },
  "license": "MIT",
  "homepage": "https://github.com/knifter/lib-soogh",
  "dependencies": {
    "lvgl/lvgl": "https://github.com/lvgl/lvgl.git#release/v9.2",
    "lovyan03/LovyanGFX": "^1.2",
    "lib-tools": "https://github.com/knifter/lib-tools",
    "esp-arduino-libs/ESP32_Display_Panel": "https://github.com/esp-arduino-libs/ESP32_Display_Panel#v1.0.4"
  },
  "frameworks": "arduino",
  "platforms": "espressif32",
  "build": {
    "srcDir": "src",
    "includeDir": "include"
  }
